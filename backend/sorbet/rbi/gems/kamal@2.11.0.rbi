# pkg:gem/kamal#lib/kamal/sshkit_with_ext.rb:9
class SSHKit::Backend::Abstract
  include ::SSHKit::Backend::Abstract::CommandEnvMerge

  # pkg:gem/kamal#lib/kamal/sshkit_with_ext.rb:14
